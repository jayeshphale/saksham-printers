# Backend Environment Configuration
PORT=5000

# MongoDB Configuration
MONGO_URI=mongodb+srv://<YOUR_USERNAME>:<YOUR_PASSWORD>@cluster0.xxxxxxxx.mongodb.net/printing_press?retryWrites=true&w=majority

# JSON Web Token Secret (Admin Authentication)
JWT_SECRET=super_secret_jwt_key_example

# Cloudinary File Uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
